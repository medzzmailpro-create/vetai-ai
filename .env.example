# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # Côté serveur uniquement

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ─── Admin ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL=your_admin_email@example.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...             # Côté serveur uniquement
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...           # Côté serveur uniquement
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/...

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # Côté serveur uniquement

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                     # Côté serveur uniquement
CONTACT_NOTIFY_EMAIL=your_email@example.com

# ─── Retell AI (Téléphone) ────────────────────────────────────────────────────
RETELL_API_KEY=your_retell_api_key        # Côté serveur uniquement
RETELL_PHONE_NUMBER=+33XXXXXXXXX
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret
RETELL_LLM_ID=your_retell_llm_id

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxx             # Côté serveur uniquement
TWILIO_AUTH_TOKEN=your_twilio_auth_token  # Côté serveur uniquement
TWILIO_PHONE_NUMBER=+33XXXXXXXXX

# ─── ElevenLabs (Voix) ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key    # Côté serveur uniquement
ELEVENLABS_VOICE_ID=your_voice_id

# ─── API interne ──────────────────────────────────────────────────────────────
API_TOOL_SECRET=your_random_secret_here

# ─── Divers ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PLACES_RESTANTES=3
